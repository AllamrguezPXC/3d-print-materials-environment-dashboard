APP_ENV=development
DATABASE_URL=sqlite:///./environment_monitor.db

# Sensors are configured per-row in the `sensors` table (see GET/POST
# /sensors) -- there is no global runtime sensor mode. The three vars below
# are used only by the startup seed script (backend/app/db/seed.py) to
# create the initial real Dracal + mock sensor rows on first run.
DRACAL_SERIAL_NUMBER=E27297
DRACAL_VCP_PORT=COM3
MOCK_SENSOR_COUNT=3

# Path to Dracal's `dracal-usb-get` CLI tool, used by any sensor row with
# sensor_type=dracal_cli (for Dracal devices whose Windows driver exposes
# them as a generic USB device rather than a virtual COM port). Defaults to
# relying on PATH; set to a full path if it isn't on PATH, e.g. on Windows:
# DRACAL_CLI_EXECUTABLE=C:\Program Files (x86)\DracalView\dracal-usb-get.exe
DRACAL_CLI_EXECUTABLE=dracal-usb-get

CORS_ORIGINS=http://localhost:5173

# How often (in seconds) the background auto-capture loop persists a Reading
# (+ any resulting Alert) from every active sensor, so /alerts and /readings
# history accumulate real data without anyone manually clicking "Capture
# reading now" on /history. Set to 0 to disable the loop entirely.
AUTO_CAPTURE_INTERVAL_SECONDS=30
